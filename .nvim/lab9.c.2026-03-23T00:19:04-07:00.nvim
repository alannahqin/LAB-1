 14 #define handle_error(msg)                                                      \
 15 ┆ do {                                                                         \
 16 ┆ ┆ perror(msg);                                                               \
 17 ┆ ┆ exit(EXIT_FAILURE);                                                        \
 18 ┆ } while (0)
